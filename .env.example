# Copy to `.env` and fill in. `.env` is gitignored.
# For production (Render), set these in the service's Environment settings instead.

# --- Server (secret) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...        # server-only; never expose to the browser

# --- Client (public, safe to expose; embedded in the built bundle) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
